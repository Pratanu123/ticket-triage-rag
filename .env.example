# Required for OpenAI embeddings + (later) LLM triage.
# If left empty, the embed job falls back to Chroma's local DefaultEmbeddingFunction
# so you can still sanity-check /debug/retrieve without a key.
OPENAI_API_KEY=sk-your-key-here

# Optional: LLM / embedding model overrides
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Retrieval
# CONFIDENCE_THRESHOLD used in a later stage; safe to leave set now
CONFIDENCE_THRESHOLD=0.7

# Postgres (defaults match docker-compose)
POSTGRES_USER=triage
POSTGRES_PASSWORD=triage
POSTGRES_DB=triage
