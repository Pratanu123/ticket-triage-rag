# Fully self-hosted — no API keys required.
# Models are pulled automatically by the `ollama-pull` Compose service.

# Chat / classification model (override to swap later)
OLLAMA_MODEL=llama3.1:8b

# Embedding model used for ChromaDB indexing + retrieval
OLLAMA_EMBED_MODEL=nomic-embed-text

# Confidence threshold below which tickets escalate to human review (0.0–1.0)
CONFIDENCE_THRESHOLD=0.7

# Postgres (defaults match docker-compose)
POSTGRES_USER=triage
POSTGRES_PASSWORD=triage
POSTGRES_DB=triage

# pgAdmin (http://localhost:5050)
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin

# Grafana (http://localhost:3000)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
