# Required: OpenAI API key for embeddings + classification/response generation
OPENAI_API_KEY=sk-your-key-here

# Optional: LLM / embedding model overrides (provider kept swappable via LLM_PROVIDER)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Confidence threshold below which tickets escalate to human review (0.0–1.0)
CONFIDENCE_THRESHOLD=0.7

# Postgres (defaults match docker-compose)
POSTGRES_USER=triage
POSTGRES_PASSWORD=triage
POSTGRES_DB=triage
